<?xml version="1.0" encoding="UTF-8"?>
<alps version="1.0">
    <title>BEAR.AgUi showcase — tool governance profile</title>
    <doc>Semantic descriptors for the demo tools. The descriptor type drives the
        AlpsToolPolicyInputProcessor::safeAndIdempotent policy: safe and idempotent
        tools are exposed to the LLM, unsafe ones are stripped from every request.</doc>

    <!-- input parameter semantics (AlpsContextInputProcessor / SchemaConverter fallback) -->
    <descriptor id="city" title="City name to look up"/>
    <descriptor id="topic" title="Topic keyword to search headlines for"/>
    <descriptor id="to" title="Recipient address"/>
    <descriptor id="body" title="Message body text"/>
    <descriptor id="id" title="Reminder identifier (upsert key)"/>
    <descriptor id="text" title="Reminder text"/>
    <descriptor id="query" title="Search term for a Composer package name"/>
    <descriptor id="a" title="First word or phrase"/>
    <descriptor id="b" title="Second word or phrase"/>
    <descriptor id="date" title="Date to compute for, defaults to today"/>

    <!-- tool transitions: descriptor id == tool name -->
    <descriptor id="weather_get" type="safe" title="Read-only weather lookup"/>
    <descriptor id="news_get" type="safe" title="Read-only news headline lookup"/>
    <descriptor id="message_post" type="unsafe" title="Sends a message on behalf of the user"/>
    <descriptor id="reminder_put" type="idempotent" title="Creates or replaces a reminder"/>
    <descriptor id="package_search" type="safe" title="Read-only Packagist package search"/>
    <descriptor id="word_similarity_get" type="safe" title="Read-only PHP string-similarity comparison"/>
    <descriptor id="rot13_get" type="safe" title="Read-only PHP str_rot13() cipher"/>
    <descriptor id="sun_info_get" type="safe" title="Read-only PHP date_sun_info() sunrise/sunset lookup"/>
</alps>
